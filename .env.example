# Copy to ".env" — never commit real secrets.

STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# One-time: python3 create_stripe.py onboard --email you@example.com
# Reuse the same Customer + PaymentMethod for every charge (PaymentIntent.customer + payment_method).
STRIPE_CUSTOMER_ID=cus_REPLACE_ME
STRIPE_PAYMENT_METHOD_ID=pm_REPLACE_ME

# Connect Transfer for invoice principal (not required if you mock transfers — see below)
STRIPE_META_CONNECTED_ACCOUNT=acct_REPLACE_ME

# Test: real Stripe charges + simulated Connect Transfer (no platform balance needed)
# BILLPAY_MOCK_CONNECT_TRANSFER=1
